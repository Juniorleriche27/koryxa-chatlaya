[Unit]
Description=ChatLAYA Service (KORYXA)
After=network.target

[Service]
User=innova
WorkingDirectory=/opt/innovaplus/KORYXA/services/chatlaya-service/backend
EnvironmentFile=/etc/innovaplus/backend.env
ExecStart=/opt/innovaplus/KORYXA/services/chatlaya-service/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8012
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
